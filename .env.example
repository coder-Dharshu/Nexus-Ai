# ═══════════════════════════════════════════════════════════════
#  NEXUS AI v2.0 — Environment Configuration
#  Copy to .env  |  Secrets → system keychain via: nexus setup
# ═══════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────────
# Local:  HOST=127.0.0.1
# Docker/Cloud:  HOST=0.0.0.0 (behind nginx/traefik/reverse proxy)
HOST=127.0.0.1
PORT=8000
WORKERS=1
DEBUG=false
ENVIRONMENT=development

# ── LLM (Groq free tier = primary, no install needed) ──────────
USE_GROQ_PRIMARY=true
GROQ_PRIMARY_MODEL=llama-3.3-70b-versatile
GROQ_FAST_MODEL=llama3-8b-8192
GROQ_REASONING_MODEL=deepseek-r1-distill-llama-70b

# ── Ollama (optional, for offline/private mode) ─────────────────
USE_OLLAMA=false
OLLAMA_BASE_URL=http://127.0.0.1:11434
ORCHESTRATOR_MODEL=qwen2.5:72b
CLASSIFIER_MODEL=llama3.2:3b
CRITIC_MODEL=deepseek-r1:32b
EMBEDDING_MODEL=nomic-embed-text

# ── Cache TTLs (seconds) ─────────────────────────────────────────
CACHE_TTL_PRICES=180
CACHE_TTL_FLIGHTS=300
CACHE_TTL_WEATHER=600
CACHE_TTL_STOCKS=60
CACHE_TTL_KNOWLEDGE=3600

# ── Security ────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=10
MAX_REQUEST_BODY_KB=64
MAX_CONCURRENT_TASKS_PER_USER=3
TASK_MAX_RETRIES=3

# ── CORS (add your frontend URL) ────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:8000"]

# ── API keys (set via: nexus setup, NOT here) ───────────────────
# GROQ_API_KEY=        → console.groq.com (free)
# TELEGRAM_BOT_TOKEN=  → @BotFather on Telegram (free)
# SPOTIFY_CLIENT_ID=   → developer.spotify.com (free)
# SPOTIFY_CLIENT_SECRET= → developer.spotify.com (free)
# GMAIL_CREDENTIALS=   → console.cloud.google.com (free)
# SERPER_API_KEY=      → serper.dev (free 2500/month)
