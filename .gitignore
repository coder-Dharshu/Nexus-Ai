*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/
*.egg

# ── Virtual environments ──────────────────────────────────────────────────
venv/
.venv/
env/
ENV/
.python-version

